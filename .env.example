# DeepReader local development defaults
DEEPREADER_DATABASE_URL=sqlite:///./data/deepreader.sqlite3
DEEPREADER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Summary Backend Configuration
DEEPREADER_SUMMARY_BACKEND=local
DEEPREADER_ALLOW_REMOTE_SUMMARY_SERVICE=false
PARAGRAPH_SUMMARY_SERVICE_URL=http://127.0.0.1:8001

# Paragraph Summary Service Configuration (if running locally)
SUMMARY_SERVICE_PROVIDER=mock
SUMMARY_SERVICE_ENABLE_PROVIDER_CALLS=false
SUMMARY_SERVICE_MODEL=gemini-2.5-flash
SUMMARY_TEMPLATE_VERSION=paragraph_one_sentence_v1

SUMMARY_LANE_COUNT=10
SUMMARY_LANE_RPM=1
SUMMARY_MAX_PARALLEL_LANES=10

SUMMARY_BATCH_TARGET_TOKENS=5000
SUMMARY_BATCH_HARD_MAX_TOKENS=10000
SUMMARY_BATCH_RESERVED_OUTPUT_TOKENS=2000

SUMMARY_MAX_PROVIDER_CALLS_PER_JOB=10

# Gemini lane credentials (optional; keep local and never commit real values)
# GEMINI_API_KEY_LANE_01=replace_me
# GEMINI_API_KEY_LANE_02=replace_me
# GEMINI_API_KEY_LANE_03=replace_me
# GEMINI_API_KEY_LANE_04=replace_me
# GEMINI_API_KEY_LANE_05=replace_me
# GEMINI_API_KEY_LANE_06=replace_me
# GEMINI_API_KEY_LANE_07=replace_me
# GEMINI_API_KEY_LANE_08=replace_me
# GEMINI_API_KEY_LANE_09=replace_me
# GEMINI_API_KEY_LANE_10=replace_me

# Local Gemini validation timing
# DEEPREADER_REMOTE_SUMMARY_MAX_POLLS=180
# DEEPREADER_REMOTE_SUMMARY_POLL_INTERVAL_SECONDS=2

# Conservative one-lane Gemini validation
# SUMMARY_LANE_RPM=5
# SUMMARY_MAX_PROVIDER_CALLS_PER_JOB=6
# SUMMARY_BATCH_TARGET_TOKENS=1000
# SUMMARY_BATCH_HARD_MAX_TOKENS=3000
