# DeepReader local development defaults
DEEPREADER_DATABASE_URL=sqlite:///./data/deepreader.sqlite3
DEEPREADER_MAX_UPLOAD_BYTES=10485760
DEEPREADER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Summary Backend Configuration
DEEPREADER_SUMMARY_BACKEND=local
DEEPREADER_ALLOW_REMOTE_SUMMARY_SERVICE=false
PARAGRAPH_SUMMARY_SERVICE_URL=http://127.0.0.1:8001

# Paragraph Summary Service Configuration (if running locally)
SUMMARY_SERVICE_PROVIDER=mock
SUMMARY_LANE_COUNT=10
SUMMARY_LANE_RPM=1
